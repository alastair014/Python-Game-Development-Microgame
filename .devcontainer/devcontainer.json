{
  "name": "pygame Starter",
  "image": "mcr.microsoft.com/devcontainers/python:3.11-bullseye",

  // Install system deps needed by pygame (SDL2 etc.) + pip packages
  "onCreateCommand": "sudo apt-get update -y && sudo apt-get install -y python3-pygame libsdl2-dev libsdl2-image-dev libsdl2-mixer-dev libsdl2-ttf-dev && pip install --upgrade pip && pip install -r requirements.txt",

  // Recommended VS Code extensions
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python3",
        "editor.formatOnSave": true,
        "editor.fontSize": 14,
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  // Forward the display so pygame can render in Codespaces
  "features": {
    "ghcr.io/devcontainers/features/desktop-lite:1": {}
  },

  "forwardPorts": [6080],

  "postStartCommand": "echo '✅ Codespace ready! Run: python main.py'"
}